SUPABASE_SECRET_KEY=

# Pooler URL (port 6543) for the app
DATABASE_URL=
# Direct URL (port 5432) for migrations only
DIRECT_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

APP_URL=http://localhost:3000

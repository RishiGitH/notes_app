# Canonical env contract. See AGENTS.md section 1.
# Do not invent new names. Client-visible vars use the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_SUPABASE_URL=
# Server-side read (SSR, Server Actions, middleware) — no NEXT_PUBLIC_ needed
SUPABASE_PUBLISHABLE_KEY=
# Client-side browser Supabase client — must be NEXT_PUBLIC_ so Next.js inlines it
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Never import from a module that ships to the client bundle.
SUPABASE_SECRET_KEY=

# Pooler URL (port 6543) for the app
# Local dev (supabase start): postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=
# Direct URL (port 5432) for migrations only
# Local dev (supabase start): postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=

MODEL_ACCESS_KEY=
DO_MODEL=anthropic-claude-4.6-sonnet
DO_INFERENCE_ENDPOINT=https://inference.do-ai.run/v1/chat/completions

APP_URL=http://localhost:3000
